# Example 2 — Filter transfers above a minimum value
query = """
query {
  FiatTokenProxy_Transfer(
    where: { value: { _gte: "1000000000000000" } }
    order_by: { value: desc }
    limit: 10
  ) {
    id
    from
    to
    value
  }
}
"""

response = requests.post(ENDPOINT, json={"query": query}, headers=HEADERS)
data = response.json()
for transfer in data["data"]["FiatTokenProxy_Transfer"]:
    print(transfer)
