# Example 3 — Transfers from a specific address
address = "0xFaEc9cDC3Ef75713b48f46057B98BA04885e3391"

query = f"""
query {{
  FiatTokenProxy_Transfer(
    where: {{ from: {{ _eq: "{address}" }} }}
    order_by: {{ value: desc }}
    limit: 10
  ) {{
    id
    from
    to
    value
  }}
}}
"""

response = requests.post(ENDPOINT, json={"query": query}, headers=HEADERS)
data = response.json()
for transfer in data["data"]["FiatTokenProxy_Transfer"]:
    print(transfer)
# Example 4 — Aggregate stats: count, sum, avg, max
query = """
query {
  FiatTokenProxy_Transfer_aggregate {
    aggregate {
      count
      sum { value }
      avg { value }
      max { value }
    }
  }
}
"""

response = requests.post(ENDPOINT, json={"query": query}, headers=HEADERS)
data = response.json()
agg = data["data"]["FiatTokenProxy_Transfer_aggregate"]["aggregate"]
print("Total transfers:", agg["count"])
print("Sum of values  :", agg["sum"]["value"])
print("Average value  :", agg["avg"]["value"])
print("Max value      :", agg["max"]["value"])
# Example 5 — Pagination: browse transfers page by page
PAGE_SIZE = 5

query = """
query($limit: Int!, $offset: Int!) {
  FiatTokenProxy_Transfer(
    limit: $limit
    offset: $offset
    order_by: { value: desc }
  ) {
    id
    from
    to
    value
  }
}
"""

for page in range(3):
    response = requests.post(
        ENDPOINT,
        json={"query": query, "variables": {"limit": PAGE_SIZE, "offset": page * PAGE_SIZE}},
        headers=HEADERS
    )
    transfers = response.json()["data"]["FiatTokenProxy_Transfer"]
    print(f"--- Page {page + 1} ---")
    for t in transfers:
        print(t)
# Example 6 — Transfers involving an address (sent OR received)
address = "0xFaEc9cDC3Ef75713b48f46057B98BA04885e3391"

query = f"""
query {{
  FiatTokenProxy_Transfer(
    where: {{
      _or: [
        {{ from: {{ _eq: "{address}" }} }}
        {{ to: {{ _eq: "{address}" }} }}
      ]
    }}
    order_by: {{ value: desc }}
    limit: 10
  ) {{
    id
    from
    to
    value
  }}
}}
"""

response = requests.post(ENDPOINT, json={"query": query}, headers=HEADERS)
data = response.json()
for transfer in data["data"]["FiatTokenProxy_Transfer"]:
    direction = "SENT" if transfer["from"] == address else "RECEIVED"
    print(f"[{direction}]", transfer)



Envio Indexer
Please refer to the documentation website for a thorough guide on all Envio indexer features

Run
pnpm dev
Visit http://localhost:8080 to see the GraphQL Playground, local password is testing.

Generate files from config.yaml or schema.graphql
pnpm codegen
Pre-requisites
Node.js (use v18 or newer)
pnpm (use v8 or newer)
Docker desktop

